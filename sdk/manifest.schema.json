{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Crawshrimp Adapter Manifest",
  "type": "object",
  "required": ["id", "name", "entry_url", "tasks"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "icon": { "type": "string" },
    "author": { "type": "string" },
    "description": { "type": "string" },
    "entry_url": { "type": "string", "format": "uri" },
    "auth": {
      "type": "object",
      "properties": {
        "check_script": { "type": "string" },
        "login_url": { "type": "string", "format": "uri" }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "script"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "script": { "type": "string" },
          "trigger": {
            "type": "object",
            "properties": {
              "type": { "enum": ["manual", "interval", "cron"] },
              "interval_minutes": { "type": "integer", "minimum": 1 },
              "cron": { "type": "string" }
            }
          },
          "output": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "enum": ["excel", "json", "sqlite", "notify"] },
                "filename": { "type": "string" },
                "channel": { "enum": ["dingtalk", "feishu", "webhook"] },
                "condition": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
